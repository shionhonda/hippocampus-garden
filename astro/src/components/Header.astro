---
import { site } from "../data/site"
---

<header class="site-header">
  <div class="container shell site-header-inner">
    <a href="#main" class="sr-only">Skip to content</a>
    <div class="site-header-row">
      <div class="site-identity">
        <a
          href="/"
          class="site-title-link"
        >
          <span class="site-emblem" aria-hidden="true"></span>
          <span>{site.title}</span>
        </a>
        <div class="site-tagline">Machine learning, software, books, notes</div>
      </div>
      <nav aria-label="Primary" class="site-nav-shell">
        <ul class="site-nav">
          <li><a href="/">Home</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/topics/">Topics</a></li>
        </ul>
      </nav>
    </div>
  </div>
</header>
