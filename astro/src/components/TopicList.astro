---
const {
  topics,
} = Astro.props as {
  topics: { label: string; slug: string; count: number }[]
}
---

<div style="display:flex;gap:var(--space-2);flex-wrap:wrap;">
  {topics.map((topic) => (
    <a
      href={`/topics/${topic.slug}/`}
      class="panel"
      style="padding:0.5rem 0.75rem;border-radius:var(--radius-pill);text-decoration:none;font-family:var(--font-ui);font-size:var(--text-sm);"
    >
      {topic.label} <span style="color:var(--color-muted);">({topic.count})</span>
    </a>
  ))}
</div>
