---
import { getProfile, type Locale } from "../data/profile"
import { getAllPosts, getPostPath, getSelectedWriting } from "../lib/posts"
import PageLayout from "../layouts/PageLayout.astro"

const { locale } = Astro.props as {
  locale: Locale
  lang?: string
  alternates?: Array<{ hrefLang: string; href: string }>
}

const profile = getProfile(locale)
const posts = await getAllPosts()
const selectedWriting = await getSelectedWriting(posts, profile.selectedWritingSlugs)
const isJapanese = locale === "ja"
const writingLanguageLabel = {
  en: { en: "English", ja: "Japanese" },
  ja: { en: "英語", ja: "日本語" },
} as const
const languageLinks = [
  {
    code: "en",
    label: profile.languageSwitchLabels.en,
    href: "/about/",
    current: locale === "en",
  },
  {
    code: "ja",
    label: profile.languageSwitchLabels.ja,
    href: "/about-ja/",
    current: locale === "ja",
  },
]
---

<PageLayout
  title={profile.pageTitle}
  description={profile.aboutSummary}
  lang={Astro.props.lang}
  alternates={Astro.props.alternates}
>
  <section class="section about-shell">
    <div class="about-topbar">
      <nav aria-label={profile.sectionLabels.switchLanguage}>
        <ul class="language-switch">
          {languageLinks.map((item) => (
            <li>
              <a
                href={item.href}
                hreflang={item.code}
                aria-current={item.current ? "page" : undefined}
                class:list={["language-pill", { current: item.current }]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
    <h1 class="intro-title">{profile.name}</h1>
    <div class="intro-meta">
      {profile.role} · {profile.location} · {profile.currentCompany}
    </div>
    <div class="intro-copy prose" set:html={profile.introHtml} />
    <div class="social-row">
      {profile.socials.map((social) => (
        <a href={social.href} target="_blank" rel="noreferrer">{social.label}</a>
      ))}
    </div>
  </section>

  <section class="section about-shell">
    <div class="section-header about-section-header">
      <div>
        <h2 class="section-title">{profile.sectionLabels.focusTitle}</h2>
      </div>
    </div>
    <div class="panel surface about-panel">
      <ul class="focus-list">
        {profile.focus.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section about-shell">
    <div class="section-header about-section-header">
      <div>
        <h2 class="section-title">{profile.sectionLabels.selectedWritingTitle}</h2>
      </div>
    </div>
    <div class="compact-link-list">
      {selectedWriting.map((post) => (
        <article class="compact-link-item">
          <a href={getPostPath(post)} style="text-decoration:none;color:inherit;">
            <h3 class="writing-title">{post.data.title}</h3>
          </a>
          <p class="writing-description">{post.data.description}</p>
          <div class="writing-language">
            {post.data.lang === "ja"
              ? writingLanguageLabel[locale].ja
              : writingLanguageLabel[locale].en}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section about-shell">
    <div class="section-header about-section-header">
      <div>
        <h2 class="section-title">{profile.sectionLabels.careerTitle}</h2>
      </div>
    </div>
    <div class="timeline">
      {profile.career.map((item) => (
        <article class="timeline-item">
          <div class="timeline-period">{item.period}</div>
          <div class="timeline-marker" aria-hidden="true"></div>
          <div class="timeline-body">
            <h3 class="timeline-title">{item.title}</h3>
            <p class="timeline-detail">{item.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section about-shell">
    <div class="section-header about-section-header">
      <div>
        <h2 class="section-title">{profile.sectionLabels.booksTitle}</h2>
      </div>
    </div>
    <div class="divider-list">
      {profile.booksAndWriting.map((item) => (
        <article class="divider-item">
          <div class="resource-meta">
            <span>{item.kind}</span>
            <span>{item.language}</span>
          </div>
          <a
            href={item.href}
            target="_blank"
            rel="noreferrer"
            class="resource-link"
          >
            {item.label}
          </a>
          {item.originalTitle && (
            <p class="resource-original">
              {isJapanese ? "原題: " : "Original title: "}
              {item.originalTitle}
            </p>
          )}
          <p class="resource-note">{item.note}</p>
        </article>
      ))}
    </div>
  </section>
</PageLayout>

<style>
  .about-shell {
    max-width: var(--width-wide-max);
    margin-inline: auto;
  }

  .about-topbar {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-4);
    align-items: center;
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .language-switch {
    display: flex;
    gap: var(--space-2);
    list-style: none;
    margin: 0;
    padding: 0;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
  }

  .language-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    border: 1px solid rgba(197, 210, 215, 0.82);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    color: var(--color-ink-soft);
  }

  .language-pill.current {
    border-color: rgba(14, 63, 82, 0.24);
    background: rgba(14, 63, 82, 0.08);
    color: var(--color-ink-strong);
  }

  .intro-title {
    margin: 0 0 var(--space-2);
    font-family: var(--font-ui);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .intro-meta {
    margin-bottom: var(--space-4);
    font-family: var(--font-ui);
    color: var(--color-muted);
  }

  .intro-copy {
    width: 100%;
    max-width: none;
    margin-inline: 0;
    color: var(--color-ink-soft);
  }

  .intro-copy :global(p) {
    margin: 0;
  }

  .social-row {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-4);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
  }

  .about-section-header {
    margin-bottom: var(--space-4);
  }

  .about-panel {
    padding: var(--space-5);
  }

  .focus-list {
    margin: 0;
    padding-left: 1.15rem;
  }

  .focus-list li + li {
    margin-top: var(--space-2);
  }

  .writing-title {
    margin: 0 0 var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-xl);
    line-height: 1.12;
  }

  .writing-description {
    margin: 0;
    color: var(--color-ink-soft);
  }

  .writing-language {
    margin-top: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .timeline {
    position: relative;
    display: grid;
    gap: var(--space-4);
  }

  .timeline::before {
    content: "";
    position: absolute;
    top: 0.7rem;
    bottom: 0.7rem;
    left: 7.1rem;
    width: 1px;
    background: rgba(197, 210, 215, 0.88);
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: 6rem 1.1rem minmax(0, 1fr);
    gap: var(--space-4);
    align-items: start;
  }

  .timeline-period {
    padding-top: 0.1rem;
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--color-muted);
    text-align: right;
  }

  .timeline-marker {
    position: relative;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.1rem;
  }

  .timeline-marker::before {
    content: "";
    position: absolute;
    inset: 0.19rem;
    border-radius: 999px;
    background: var(--color-reef-surface);
    box-shadow: 0 0 0 0.24rem rgba(158, 223, 214, 0.28);
  }

  .timeline-body {
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-5);
    border: 1px solid rgba(197, 210, 215, 0.7);
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.76);
  }

  .timeline-title {
    margin: 0 0 var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-lg);
  }

  .timeline-detail {
    margin: 0;
    color: var(--color-ink-soft);
  }

  .resource-meta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .resource-link {
    font-family: var(--font-ui);
    font-size: var(--text-lg);
  }

  .resource-original,
  .resource-note {
    margin: var(--space-2) 0 0;
    color: var(--color-ink-soft);
  }

  @media (max-width: 720px) {
    .timeline::before {
      left: 0.55rem;
    }

    .timeline-item {
      grid-template-columns: 1.1rem minmax(0, 1fr);
      gap: var(--space-3);
    }

    .timeline-period {
      grid-column: 2;
      text-align: left;
      padding-top: 0;
      margin-bottom: calc(var(--space-2) * -1);
    }

    .timeline-marker {
      grid-row: 1 / span 2;
    }

    .timeline-body {
      grid-column: 2;
      padding-left: var(--space-4);
    }
  }
</style>
