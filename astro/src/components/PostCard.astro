---
import type { CollectionEntry } from "astro:content"
import { getPostPath, getReadingTime } from "../lib/posts"

const { post } = Astro.props as { post: CollectionEntry<"posts"> }
---

<article class="panel" style="padding:var(--space-5);height:100%;">
  <a href={getPostPath(post)} style="text-decoration:none;color:inherit;">
    <h2
      style="font-family:var(--font-ui);font-size:var(--text-2xl);line-height:var(--leading-snug);margin:0 0 var(--space-3);color:var(--color-ink-strong);"
    >
      {post.data.title}
    </h2>
  </a>
  <p style="margin:0 0 var(--space-4);color:var(--color-ink-soft);">
    {post.data.description}
  </p>
  <div
    style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-muted);display:flex;gap:var(--space-3);flex-wrap:wrap;"
  >
    <span>{post.data.date.toISOString().slice(0, 10)}</span>
    <span>{getReadingTime(post)} min read</span>
    {post.data.lang ? <span>{post.data.lang.toUpperCase()}</span> : null}
  </div>
</article>
