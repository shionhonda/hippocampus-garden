---
import type { CollectionEntry } from "astro:content"
import { getPostPath, getReadingTime } from "../lib/posts"

const { post } = Astro.props as { post: CollectionEntry<"posts"> }
---

<article class="divider-item" style="height:100%;">
  <div class="eyebrow" style="margin-bottom:var(--space-3);">
    {post.data.date.toISOString().slice(0, 10)} · {getReadingTime(post)} min read{post.data.lang ? ` · ${post.data.lang.toUpperCase()}` : ""}
  </div>
  <a href={getPostPath(post)} style="text-decoration:none;color:inherit;">
    <h2
      style="font-family:var(--font-ui);font-size:clamp(1.5rem, 2.2vw, 1.9rem);line-height:1.08;letter-spacing:-0.02em;margin:0 0 var(--space-3);color:var(--color-ink-strong);max-width:22ch;"
    >
      {post.data.title}
    </h2>
  </a>
  <p style="margin:0;max-width:37rem;color:var(--color-ink-soft);">
    {post.data.description}
  </p>
</article>
