---
const year = new Date().getFullYear()
---

<footer style="border-top:1px solid var(--color-line-soft);margin-top:var(--space-16);">
  <div
    class="container shell"
    style="padding-block:var(--space-8);display:flex;justify-content:space-between;gap:var(--space-4);flex-wrap:wrap;font-family:var(--font-ui);font-size:var(--text-sm);color:var(--color-muted);"
  >
    <div>Hippocampus&apos;s Garden © {year}</div>
    <nav aria-label="Footer">
      <ul style="display:flex;gap:var(--space-4);list-style:none;padding:0;margin:0;">
        <li><a href="/about/">About</a></li>
        <li><a href="/topics/">Topics</a></li>
        <li><a href="/privacy-policy/">Privacy Policy</a></li>
        <li>
          <button type="button" class="footer-cookie-button" data-cookie-settings-button>
            Cookie Settings
          </button>
        </li>
        <li><a href="/rss.xml">RSS</a></li>
      </ul>
    </nav>
  </div>
</footer>

<script>
  import { reopenCookieConsent } from "../lib/cookie-consent"

  const setupCookieSettingsButton = () => {
    document
      .querySelector<HTMLButtonElement>("[data-cookie-settings-button]")
      ?.addEventListener("click", () => {
        reopenCookieConsent()
      })
  }

  document.addEventListener("astro:page-load", setupCookieSettingsButton)
  setupCookieSettingsButton()
</script>
