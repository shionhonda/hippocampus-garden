---
const { currentPage, totalPages } = Astro.props as {
  currentPage: number
  totalPages: number
}

const hrefForPage = (page: number) => (page === 1 ? "/" : `/page/${page}/`)
---

{
  totalPages > 1 && (
    <nav aria-label="Pagination" style="margin-top:var(--space-8);">
      <ul style="display:flex;gap:var(--space-2);flex-wrap:wrap;list-style:none;padding:0;margin:0;font-family:var(--font-ui);">
        {Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
          <li>
            <a
              href={hrefForPage(page)}
              aria-current={page === currentPage ? "page" : undefined}
              class="panel"
              style={`display:inline-block;padding:0.6rem 0.9rem;text-decoration:none;color:inherit;border-color:${page === currentPage ? "var(--color-line-strong)" : "var(--color-line-soft)"};`}
            >
              {page}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
