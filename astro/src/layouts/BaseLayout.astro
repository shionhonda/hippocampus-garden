---
import "../styles/global.css"
import CookieConsentBanner from "../components/CookieConsentBanner.astro"
import Footer from "../components/Footer.astro"
import Header from "../components/Header.astro"
import { site } from "../data/site"

const {
  title,
  description = site.description,
  lang = site.locale,
  alternates = [],
} = Astro.props as {
  title?: string
  description?: string
  lang?: string
  alternates?: Array<{ hrefLang: string; href: string }>
}
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | ${site.title}` : site.title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3f8f8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />
    ))}
  </head>
  <body>
    <Header />
    <CookieConsentBanner />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import { getCookieConsent, initializeAnalytics, trackPageView } from "../lib/cookie-consent"

  const setupAnalytics = () => {
    if (getCookieConsent() !== "accepted") {
      return
    }

    initializeAnalytics()
    trackPageView()
  }

  document.addEventListener("astro:page-load", setupAnalytics)
  setupAnalytics()
</script>
