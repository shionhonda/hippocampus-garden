---
import "../styles/global.css"
import CookieConsentBanner from "../components/CookieConsentBanner.astro"
import Footer from "../components/Footer.astro"
import Header from "../components/Header.astro"
import { site } from "../data/site"
import { getDefaultSocialImage, toAbsoluteUrl } from "../lib/seo"

const {
  title,
  description = site.description,
  lang = site.locale,
  alternates = [],
  canonicalPath,
  canonicalUrl,
  socialImage = getDefaultSocialImage(),
  ogType = "website",
  noindex = false,
} = Astro.props as {
  title?: string
  description?: string
  lang?: string
  alternates?: Array<{ hrefLang: string; href: string }>
  canonicalPath?: string
  canonicalUrl?: string
  socialImage?: string
  ogType?: "website" | "article"
  noindex?: boolean
}

const pageTitle = title ? `${title} | ${site.title}` : site.title
const resolvedCanonicalUrl =
  canonicalUrl ?? toAbsoluteUrl(canonicalPath ?? Astro.url.pathname)
const resolvedSocialImage = socialImage ?? getDefaultSocialImage()
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3f8f8" />
    <link rel="canonical" href={resolvedCanonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content={lang} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonicalUrl} />
    <meta property="og:image" content={resolvedSocialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedSocialImage} />
    <meta name="twitter:creator" content={site.twitterHandle} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />
    ))}
  </head>
  <body>
    <Header />
    <CookieConsentBanner />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import { initializeAnalytics, trackPageView } from "../lib/cookie-consent"

  const setupAnalytics = () => {
    initializeAnalytics()
    trackPageView()
  }

  const unregisterLegacyServiceWorkers = async () => {
    if (!("serviceWorker" in navigator) || !("caches" in window)) {
      return
    }

    try {
      const registrations = await navigator.serviceWorker.getRegistrations()
      await Promise.all(
        registrations.map(async (registration) => {
          try {
            await registration.update()
          } catch {}
        }),
      )

      await navigator.serviceWorker.register("/sw.js")

      const cacheKeys = await caches.keys()
      await Promise.all(cacheKeys.map((cacheKey) => caches.delete(cacheKey)))

      await Promise.all(
        registrations.map(async (registration) => {
          try {
            await registration.unregister()
          } catch {}
        }),
      )
    } catch {}
  }

  const handleControllerChange = () => {
    if (sessionStorage.getItem("legacy-sw-cleanup-reloaded") === "1") {
      return
    }

    sessionStorage.setItem("legacy-sw-cleanup-reloaded", "1")
    window.location.reload()
  }

  document.addEventListener("astro:page-load", setupAnalytics)
  window.addEventListener("load", unregisterLegacyServiceWorkers)
  navigator.serviceWorker?.addEventListener("controllerchange", handleControllerChange)
  setupAnalytics()
</script>
