---
import PageLayout from "../layouts/PageLayout.astro"
---

<PageLayout title="Not Found" canonicalPath="/404.html" noindex={true}>
  <section class="section" style="max-width:var(--width-content-max);">
    <div class="panel" style="padding:var(--space-6);">
      <h1 style="font-family:var(--font-ui);margin-top:0;">Page not found</h1>
      <p>The page you are looking for does not exist in the Astro site scaffold.</p>
      <a href="/">Back to home</a>
    </div>
  </section>
</PageLayout>
