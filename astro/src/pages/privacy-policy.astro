---
import PageLayout from "../layouts/PageLayout.astro"
---

<PageLayout title="Privacy Policy">
  <section class="section" style="max-width:var(--width-content-max);">
    <div class="panel" style="padding:var(--space-6);">
      <h1 style="font-family:var(--font-ui);margin-top:0;">Privacy Policy</h1>
      <p>
        This page is part of the Astro scaffold. Migrate the existing privacy policy
        content here during the content migration step.
      </p>
    </div>
  </section>
</PageLayout>
