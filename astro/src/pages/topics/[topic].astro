---
import PageLayout from "../../layouts/PageLayout.astro"
import PostCard from "../../components/PostCard.astro"
import { getPostsForTopic } from "../../lib/posts"
import { getAllTopics } from "../../lib/topics"

export async function getStaticPaths() {
  const { getAllPosts } = await import("../../lib/posts")
  const posts = await getAllPosts()
  const topics = getAllTopics(posts)
  return topics.map((topic) => ({
    params: { topic: topic.slug },
    props: { topic },
  }))
}

const { topic } = Astro.props
const posts = await getPostsForTopic(topic.slug)
---

<PageLayout
  title={topic.label}
  description={`Posts filed under ${topic.label}.`}
  canonicalPath={`/topics/${topic.slug}/`}
>
  <section class="section" style="max-width:var(--width-wide-max);margin-inline:auto;">
    <div class="section-header">
      <div>
        <div class="eyebrow" style="margin-bottom:var(--space-2);">Topic</div>
        <h1 class="section-title" style="font-size:var(--text-3xl);">{topic.label}</h1>
      </div>
      <p style="margin:0;color:var(--color-muted);">{topic.count} posts</p>
    </div>
    <div class="divider-list">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</PageLayout>
