---
import { render } from "astro:content"
import AuthorSummary from "../components/AuthorSummary.astro"
import PostCard from "../components/PostCard.astro"
import PostLayout from "../layouts/PostLayout.astro"
import { getAllPosts, getPostSlug, getReadingTime, getRelatedPosts } from "../lib/posts"

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)
const relatedPosts = await getRelatedPosts(post)
---

<PostLayout title={post.data.title} description={post.data.description}>
  <article class="prose">
    <header class="article-head">
      <div class="eyebrow">Essay</div>
      <div>
        <h1 class="article-title">{post.data.title}</h1>
      </div>
      <p class="article-dek">{post.data.description}</p>
      <div class="meta-row">
        <span>{post.data.date.toISOString().slice(0, 10)}</span>
        <span>{getReadingTime(post)} min read</span>
        {post.data.lang ? <span>{post.data.lang.toUpperCase()}</span> : null}
      </div>
    </header>

    {headings.length >= 4 && (
      <details class="panel surface" style="padding:var(--space-4);margin-bottom:var(--space-8);">
        <summary style="font-family:var(--font-ui);cursor:pointer;">Table of contents</summary>
        <ul style="margin:var(--space-3) 0 0;padding-left:1.2rem;">
          {headings.map((heading) => (
            <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
          ))}
        </ul>
      </details>
    )}

    <Content />
  </article>

  {relatedPosts.length > 0 && (
    <section class="section">
      <div class="section-header">
        <div>
          <div class="eyebrow" style="margin-bottom:var(--space-2);">Continue reading</div>
          <h2 class="section-title">Related posts</h2>
        </div>
      </div>
      <div class="divider-list">
        {relatedPosts.map((relatedPost) => <PostCard post={relatedPost} />)}
      </div>
    </section>
  )}

  <section class="section" style="max-width:var(--width-content-max);">
    <AuthorSummary />
  </section>
</PostLayout>
