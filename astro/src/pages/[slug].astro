---
import { render } from "astro:content"
import AuthorSummary from "../components/AuthorSummary.astro"
import PostCard from "../components/PostCard.astro"
import TableOfContents from "../components/TableOfContents.astro"
import PostLayout from "../layouts/PostLayout.astro"
import { getAllPosts, getPostSlug, getReadingTime, getRelatedPosts } from "../lib/posts"

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)
const relatedPosts = await getRelatedPosts(post)
---

<PostLayout title={post.data.title} description={post.data.description}>
  <article class="prose">
    <header class="article-head">
      <div class="eyebrow">Essay</div>
      <div>
        <h1 class="article-title">{post.data.title}</h1>
      </div>
      <p class="article-dek">{post.data.description}</p>
      <div class="meta-row">
        <span>{post.data.date.toISOString().slice(0, 10)}</span>
        <span>{getReadingTime(post)} min read</span>
        {post.data.lang ? <span>{post.data.lang.toUpperCase()}</span> : null}
      </div>
    </header>

    {headings.length >= 4 && <TableOfContents headings={headings} />}

    <Content />
  </article>

  {relatedPosts.length > 0 && (
    <section class="section">
      <div class="section-header">
        <div>
          <div class="eyebrow" style="margin-bottom:var(--space-2);">Continue reading</div>
          <h2 class="section-title">Related posts</h2>
        </div>
      </div>
      <div class="divider-list">
        {relatedPosts.map((relatedPost) => <PostCard post={relatedPost} />)}
      </div>
    </section>
  )}

  <section class="section" style="max-width:var(--width-content-max);margin-inline:auto;">
    <AuthorSummary />
  </section>
</PostLayout>
